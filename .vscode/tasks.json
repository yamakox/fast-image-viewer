{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "T001: backendのセットアップ",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "command": "uv sync"
    },
    {
      "label": "T002: frontendのセットアップ",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "command": "npm i"
    },
    {
      "label": "T011: DBのセットアップ・マイグレーション",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "command": "uv run manage.py makemigrations && uv run manage.py migrate"
    },
    {
      "label": "T012: データセットフォルダーのスキャン",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "command": "uv run manage.py scan_dataset"
    },
    {
      "label": "T013: Django shellの起動",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "command": "uv run manage.py shell"
    },
    {
      "label": "T021: デバッグモードでbackend起動",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "command": "uv run -m debugpy --listen localhost:8001 main.py"
    },
    {
      "label": "T022: frontend起動 (npm run dev)",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "command": "npm run dev"
    },
    {
      "label": "T031: backendのソースコードチェック",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "command": "uv run ruff check"
    },
    {
      "label": "T032: backendのソースコード書式整形",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "command": "uv run ruff format"
    },
    {
      "label": "T033: frontendのソースコードチェック",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "command": "npx oxlint"
    },
    {
      "label": "T034: frontendのソースコード書式整形",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "command": "npm run format"
    },
    {
      "label": "T035: Vueアプリのビルド",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "command": "npm run build"
    }
  ]
}
