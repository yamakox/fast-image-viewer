{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "T001: backendのセットアップ",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "command": "uv sync"
    },
    {
      "label": "T002: frontendのセットアップ",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "command": "npm i"
    },
    {
      "label": "T011: DBのセットアップ・マイグレーション",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "command": "uv run manage.py makemigrations api && uv run manage.py migrate"
    },
    {
      "label": "T012: データセットフォルダーのスキャン",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "command": "uv run manage.py scan_dataset"
    },
    {
      "label": "T013: Django shellの起動",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "command": "uv run manage.py shell"
    },
    {
      "label": "T021: backend起動 (本番モード)",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "DEBUG": "False",
          "WORKERS": "16"
        }
      },
      "command": "uv run main.py"
    },
    {
      "label": "T022: backend起動 (デバッグモード)",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "command": "uv run -m debugpy --listen localhost:8001 -m uvicorn --host=localhost --port=8000 fast_image_viewer.asgi:application --reload"
    },
    {
      "label": "T023: frontend起動 (npm run dev)",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "command": "npm run dev"
    },
    {
      "label": "T031: backendのソースコードチェック",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "command": "uv run ruff check"
    },
    {
      "label": "T032: backendのソースコード書式整形",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "command": "uv run ruff format"
    },
    {
      "label": "T033: frontendのソースコードチェック",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "command": "npx oxlint"
    },
    {
      "label": "T034: frontendのソースコード書式整形",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "command": "npm run format"
    },
    {
      "label": "T035: Vueアプリのビルド",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "command": "npm run build"
    },
    {
      "label": "T041: Dockerコンテナイメージのビルド",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "command": "docker compose build"
    },
    {
      "label": "T042: Dockerコンテナイメージとアプリデータの削除",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "command": "docker compose down --volumes --rmi all"
    },
    {
      "label": "T043: Dockerコンテナのデータベースマイグレーション",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "command": "docker compose run -i --rm app uv run manage.py migrate"
    },
    {
      "label": "T044: Dockerコンテナのデータセットスキャン",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "command": "docker compose run -i --rm app uv run manage.py scan_dataset"
    },
    {
      "label": "T045: Dockerコンテナの起動",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "command": "docker compose up -d"
    },
    {
      "label": "T046: Dockerコンテナの停止",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "command": "docker compose down"
    }
  ]
}
